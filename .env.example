# ─────────────────────────────────────────────────────────────
# Supabase — public (safe to expose; RLS enforces access)
# Used by: apps/web, apps/admin (public reads)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# Admin only — SERVER SIDE. In real deploys these come from
# Vercel env vars, never committed.
# ─────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=
# Google OAuth — from Google Cloud Console > APIs & Services > Credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=                    # run: openssl rand -base64 32
ADMIN_EMAIL=                    # the only Google account allowed to access admin

# Upstash Redis — optional, admin rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ISR on-demand revalidation (admin -> web)
REVALIDATE_SECRET=
# Full URL of the web app's revalidate endpoint (admin calls this on save)
# e.g. https://your-web-app.vercel.app/api/revalidate  (or http://localhost:3000/api/revalidate in dev)
WEB_REVALIDATE_URL=

# ─────────────────────────────────────────────────────────────
# Mobile (Expo) — public
# ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
