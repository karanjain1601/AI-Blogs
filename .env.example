# ─────────────────────────────────────────────────────────────
# Supabase — public (safe to expose; RLS enforces access)
# Used by: apps/web, apps/admin (public reads)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# Admin only — SERVER SIDE. In real deploys these come from
# GitHub Secrets, never committed. See Plan/plan.md.
# ─────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=            # argon2id hash (never the plaintext password)
SESSION_SECRET=                 # long random string, signs the session cookie
ADMIN_TOTP_SECRET=              # base32 TOTP secret for 2FA

# Upstash Redis — admin login rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ISR on-demand revalidation (admin -> web)
REVALIDATE_SECRET=
# Full URL of the web app's revalidate endpoint (admin calls this on save)
# e.g. https://your-web-app.vercel.app/api/revalidate  (or http://localhost:3000/api/revalidate in dev)
WEB_REVALIDATE_URL=

# ─────────────────────────────────────────────────────────────
# Mobile (Expo) — public
# ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
