# Public (safe in client bundles)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# Giscus comments (optional — leave empty to disable)
NEXT_PUBLIC_GISCUS_REPO=username/repo
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Server-side only
REVALIDATE_SECRET=             # shared with admin app

# Cron jobs (optional — needed for scheduled publish + backup)
SUPABASE_SERVICE_ROLE_KEY=     # only for cron routes, never in client
CRON_SECRET=                   # Vercel cron auth token

# Rate limiting (optional — reactions + view counter)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# GitHub backup (optional — backs up all published notes as markdown to a repo)
# Repo must exist with at least one commit. Use a fine-grained PAT with Contents write scope.
GITHUB_BACKUP_TOKEN=            # fine-grained PAT with repo Contents: read+write
GITHUB_BACKUP_REPO=             # e.g. username/notes-backup
GITHUB_BACKUP_BRANCH=main       # branch to commit to (default: main)
